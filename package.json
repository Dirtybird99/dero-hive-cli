{
  "name": "dero-hive-cli",
  "version": "0.1.0",
  "description": "Terminal-native AI coding workspace with DERO tools, skills, and MCP support",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dirtybird99/dero-hive-cli.git"
  },
  "homepage": "https://github.com/Dirtybird99/dero-hive-cli#readme",
  "bugs": {
    "url": "https://github.com/Dirtybird99/dero-hive-cli/issues"
  },
  "bin": {
    "hive": "cli/bin/hive.js"
  },
  "files": [
    "cli/bin",
    "cli/dist",
    "cli/package.json",
    "resources/mcp/dero-mcp-server/data",
    "resources/mcp/dero-mcp-server/dist",
    "resources/mcp/dero-mcp-server/LICENSE",
    "resources/mcp/dero-mcp-server/package.json",
    "resources/skills",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build-cli.mjs && node scripts/build-mcp.mjs",
    "build:cli": "node scripts/build-cli.mjs",
    "build:mcp": "node scripts/build-mcp.mjs",
    "dev": "tsx cli/src/index.ts",
    "start": "node cli/bin/hive.js",
    "hive": "node cli/bin/hive.js",
    "typecheck": "tsc --noEmit -p tsconfig.cli.json",
    "lint": "eslint \"cli/src/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx}\"",
    "test": "tsx cli/src/tui/commands.test.ts && tsx cli/src/tui/mouse.test.ts && tsx cli/src/services/conversation.test.ts && tsx cli/src/services/permissions.test.ts && tsx src/main/providers/codex-acp.test.ts && tsx cli/src/tui/render.test.ts",
    "setup:simulator": "node scripts/setup-simulator.mjs"
  },
  "dependencies": {
    "@agentclientprotocol/codex-acp": "1.1.2",
    "better-sqlite3": "^11.3.0"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "^1.2.1",
    "@eslint/js": "^10.0.1",
    "@inquirer/prompts": "^7.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/curves": "^2.2.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "esbuild": "^0.21.5",
    "eslint": "^10.6.0",
    "eventsource-parser": "^3.0.0",
    "fast-glob": "^3.3.2",
    "ink": "^5.0.0",
    "marked": "^14.1.3",
    "marked-terminal": "^7.1.0",
    "ora": "^8.1.0",
    "react": "^18.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.63.0",
    "zod": "^3.25.0"
  },
  "allowScripts": {
    "better-sqlite3@11.10.0": true,
    "esbuild@0.21.5": true,
    "esbuild@0.28.1": true
  }
}
